{
    "name": "corvet/light-symfony-bundle",
    "description": "Library for simplifying CRUD operations",
    "type": "symfony-bundle",
    "license": "MIT",
    "autoload": {
        "psr-4": {
            "Corvet\\LightSymfonyBundle\\": "src/"
        }
    },
    "authors": [
        {
            "name": "Serg Bugayov",
            "email": "serg.bugayov@gmail.com"
        }
    ],
    "require": {
        "php": "^8.1",
        "symfony/framework-bundle": "^6.4 || ^7.4 || ^8.0",
        "doctrine/orm": "^3.6",
        "symfony/form": "^6.4 || ^7.4 || ^8.0",
        "symfony/twig-bundle": "^6.4 || ^7.4 || ^8.0",
        "symfony/stimulus-bundle": "^2.9.1|^3.0",
        "symfony/dependency-injection": "^7.4|^8.0",
        "symfony/console": "^8.0 || ^7.4 || ^6.4"
    },
    "extra": {
        "symfony": {
            "bundle": "Corvet\\LightSymfonyBundle\\CorvetLightSymfonyBundle"
        }
    }
